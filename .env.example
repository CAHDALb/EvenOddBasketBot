# ==================================================
# EvenOddBasketBot
# Example configuration
# Скопируйте этот файл в ".env"
# и заполните своими значениями.
# ==================================================

# Telegram Bot Token
BOT_TOKEN=YOUR_BOT_TOKEN

# Telegram Chat IDs (через запятую)
CHAT_IDS=111111111,222222222

# Интервал проверки (секунд)
CHECK_INTERVAL=180

# PostgreSQL (Neon)
DATABASE_URL=postgresql://username:password@host/database