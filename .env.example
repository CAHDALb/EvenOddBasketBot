# ==================================================
# EvenOddBasketBot
# Example configuration
# Скопируйте этот файл в ".env"
# и заполните своими значениями.
# ==================================================

# Telegram Bot Token
BOT_TOKEN=YOUR_BOT_TOKEN

# Telegram ID владельца/администратора (через запятую).
# Для коммерческого бота рекомендуется оставить только владельца.
ADMIN_TELEGRAM_IDS=111111111

# Устаревшая переменная для совместимости. Можно оставить пустой.
CHAT_IDS=

# Интервал проверки (секунд)
CHECK_INTERVAL=180

# PostgreSQL (Neon)
DATABASE_URL=postgresql://username:password@host/database